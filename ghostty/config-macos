# macOS-specific keybinds
# Uses Cmd (super) for tab management — matches macOS conventions
# window-decoration = true recommended on macOS for native titlebars

window-decoration = true

# Quick terminal toggle
keybind = global:grave_accent=toggle_quick_terminal

# Tab switching: Cmd+1 through Cmd+9
keybind = super+1=goto_tab:1
keybind = super+2=goto_tab:2
keybind = super+3=goto_tab:3
keybind = super+4=goto_tab:4
keybind = super+5=goto_tab:5
keybind = super+6=goto_tab:6
keybind = super+7=goto_tab:7
keybind = super+8=goto_tab:8
keybind = super+9=goto_tab:9

# New tab / close tab
keybind = super+t=new_tab
keybind = super+w=close_tab:this
